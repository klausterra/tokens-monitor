OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
PROXY_MASTER_KEY=sk-local-change-me
METRICS_API_KEY=sk-metrics-change-me
HOST=0.0.0.0
PORT=4010
USAGE_DB_PATH=./data/usage.db
OPENROUTER_BASE=https://openrouter.ai/api/v1
PUBLIC_HOSTNAME=your.domain.example
DEFAULT_PROVIDER=openrouter
GUARDRAILS_PATH=./guardrails.json

# Xiaomi MiMo / MaaS (pay-as-you-go sk-... or Token Plan tp-...)
XIAOMI_MAAS_API_KEY=
# Optional overrides:
# XIAOMI_MIMO_API_KEY=
# MIMO_API_KEY=
# PayG: https://api.xiaomimimo.com/v1
# Token Plan CN: https://token-plan-cn.xiaomimimo.com/v1
# Token Plan SGP: https://token-plan-sgp.xiaomimimo.com/v1
XIAOMI_MAAS_BASE_URL=

# Huawei Cloud MaaS Token Service (research LiteLLM gateway — default)
# Docs: https://support.huaweicloud.com/intl/en-us/model-call-maas/maas-modelarts-0908.html
HUAWEI_MAAS_API_KEY=
HUAWEI_MAAS_API_STYLE=litellm
PREFER_HUAWEI_DEEPSEEK=1
# Production ModelArts console keys:
# HUAWEI_MAAS_API_STYLE=v2
# HUAWEI_MAAS_BASE_URL=https://api-ap-southeast-1.modelarts-maas.com/v2
# HUAWEI_MAAS_BASE_URL=https://api-ap-southeast-1.modelarts-maas.com/openai/v1

# Guardrails via env (optional; also editable via PUT /api/v1/guardrails)
# GUARDRAILS_ENABLED=true
# GUARDRAILS_MAX_RPM=60
# GUARDRAILS_MAX_TPM=
# GUARDRAILS_MAX_COST_USD_DAY=5
# GUARDRAILS_MAX_COST_USD_MONTH=50
# GUARDRAILS_MIN_OPENROUTER_CREDITS=0.5
# GUARDRAILS_ALLOWED_MODELS=deepseek/deepseek-v4-flash,mimo-v2.5*,glm-5*
# GUARDRAILS_BLOCKED_MODELS=
# GUARDRAILS_ALLOWED_PROVIDERS=openrouter,xiaomi,huawei,nvidia

# NVIDIA NIM / build.nvidia.com (https://integrate.api.nvidia.com/v1)
NVIDIA_API_KEY=
# NVIDIA_NIM_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Shortcuts: nv/nano → nvidia/nemotron-3-nano-30b-a3b ; nv/super → …super-120b…
